{
    "elements": [
        {
            "type": "ValidationTextBox",
            "name": "CalendarUrl",
            "caption": "AWM ICS Download URL"
        },
        {
            "type": "NumberSpinner",
            "name": "UpdateInterval",
            "caption": "Update-Intervall (Stunden)",
            "minimum": 1,
